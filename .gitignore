# Obsidian machine-specific state (not portable)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/.trash/

# Generated PDF outputs — regenerated on demand from markdown
*.pdf

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
.ruff_cache/
.env
venv/
.venv/

# Claude Code / local agent state
.claude/

# Raw intake material (old CV, LinkedIn export) — keep PII out of Git by default.
# Remove these two lines in your own private instance if you want it version-tracked.
sources/*
!sources/README.md

# Company research — holds sensitive notes (interviewer names, comp figures).
# Ignored by default; only the README and .gitkeep ship. Un-ignore your own company
# folders in a private fork. Rooted (leading /) so it never catches the committed
# worked example under examples/sample-candidate/companies/.
/companies/*
!/companies/.gitkeep
!/companies/README.md
